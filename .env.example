PORT=3000

# Optional: nur beim allerersten Start relevant (Standard ist "WM2026!").
# Danach in der App unter Einstellungen änderbar – dieser Wert wird ignoriert,
# sobald ein Passwort in der App gesetzt wurde.
# APP_PASSWORD=WM2026!

# Optional: Kostenloser API-Key von https://www.football-data.org/client/register
# Kann auch später bequem in der App unter Einstellungen eingetragen werden.
# FOOTBALL_API_KEY=dein_api_key_hier
